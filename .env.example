# Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Where the scanned PDFs live. Default is ./scans (gitignored).
# Override to point at an external drive, synced cloud folder, or a mount.
SCANS_ROOT=./scans

# Where the pipeline writes rendered pages, JSON results, and the SQLite job
# database. Default is ./data (gitignored).
DATA_ROOT=./data

# Render DPI for PDF→PNG. 300 is a good default; bump to 400 if handwriting is
# unreadable on a given decade of scans.
RENDER_DPI=300

# Gemini model. Update when Google releases a stable Gemini 3.x.
GEMINI_MODEL=gemini-3.1-pro-preview

# media_resolution sent with each call. One of: low, medium, high, ultra_high.
# high (1120 tokens/image) is the default; ultra_high helps on the worst
# handwriting at extra cost.
GEMINI_MEDIA_RESOLUTION=high

# Concurrency for the render step. pdftoppm is CPU-bound but releases the GIL
# inside the subprocess boundary, so 4-6 is a good default on a typical
# laptop. Override per-run with `flowsheets render --concurrency <N>`.
RENDER_CONCURRENCY=4

# Concurrency for the process step. Tune to fit your Gemini rate limit.
PROCESS_CONCURRENCY=4

# Max attempts before a job moves from `failed` to permanently failed.
MAX_ATTEMPTS=3
